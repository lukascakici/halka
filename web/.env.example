# Halka — environment configuration
#
# Testnet works with no configuration at all. Mainnet stays locked in the
# network switcher until every variable below is set, because a network without
# an RPC endpoint or deployed contracts fails on its first call.

# Soroban RPC for mainnet. There is no free public one — get an endpoint from a
# provider such as Blockdaemon, QuickNode or Validation Cloud.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Contracts deployed to mainnet (see docs/deployments.md).
NEXT_PUBLIC_MAINNET_FACTORY=
NEXT_PUBLIC_MAINNET_REPUTATION=

# Optional: forward in-app feedback to a Discord/Slack/Tally-style webhook.
FEEDBACK_WEBHOOK_URL=
